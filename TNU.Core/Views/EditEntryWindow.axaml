<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:enum="clr-namespace:TNU.Core.Models.Enum"
		xmlns:models="clr-namespace:TNU.Core.Models"
		xmlns:models1="clr-namespace:TNU.Core.Models"
		xmlns:repository="clr-namespace:TNU.Core.Repository"
		x:Class="TNU.Core.Views.EditEntryWindow"
		x:DataType="models1:JobEntry"
		Title="Редактирование записи о работе"
		Width="400"
		Height="250"
		WindowStartupLocation="CenterOwner"
		CanResize="False"
		Background="DarkGray">
	<StackPanel
	Margin="20">

		<TextBlock Text="Род деятельности:" />
		<AutoCompleteBox Text="{Binding JobName}"
						 ItemsSource="{x:Static repository:JobNameRepository.JobNameList}"
						 FilterMode="Contains"
						 MinimumPrefixLength="1">
			<AutoCompleteBox.ItemTemplate>
				<DataTemplate x:DataType="enum:JobTitleEnum">
					<TextBlock Text="{Binding Name}" />
				</DataTemplate>
			</AutoCompleteBox.ItemTemplate>
		</AutoCompleteBox>

		<StackPanel Orientation="Horizontal"> 
			<TextBlock Text="Время Начала:" VerticalAlignment="Center" />
			<TextBox Text="{Binding StartTime}"/>
			<TextBlock Text="Время Конца:" VerticalAlignment="Center" />
			<TextBox Text="{Binding EndTime}" />
		</StackPanel>

		<StackPanel
		Orientation="Horizontal"
		HorizontalAlignment="Right"
		Margin="0,40,0,0"
		Spacing="8">
			<Button Content="OK"
					Click="OkButton_Click"
					IsDefault="True" />
			<Button Content="Отмена"
					Click="CancelButton_Click"
					IsCancel="True" />
		</StackPanel>
	</StackPanel>
</Window>