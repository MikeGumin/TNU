<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:vm="using:TNU.ViewModels"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
		x:Class="TNU.Views.MainWindow"
		x:DataType="vm:MainWindowViewModel"

		xmlns:local="clr-namespace:TNU.Services"
		xmlns:models="using:TNU.Models"
		xmlns:repository="clr-namespace:TNU.Repository"
		xmlns:enum="clr-namespace:TNU.Models.Enum"

		FontFamily="Segoe UI, Arial, sans-serif"

		Icon="/Assets/avalonia-logo.ico"
		Title="TNU">

	<Design.DataContext>
		<!-- This only sets the DataContext for the previewer in an IDE,
		to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
		<vm:MainWindowViewModel/>
	</Design.DataContext>
	

	<Grid ShowGridLines="True">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="10"/>
			<ColumnDefinition Width="*"/>
			<ColumnDefinition Width="*"/>
			<ColumnDefinition Width="10"/>
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="30"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- Левая панель: активные записи -->
		<DockPanel Grid.Column="1" Grid.Row="1" Background="DarkGray">
			<Border>
				<ScrollViewer>
					<StackPanel>


						<ItemsControl ItemsSource="{Binding TimerList}">


							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Grid ColumnDefinitions="Auto, *, Auto, Auto,100">
										<TextBlock Grid.Column="0" Text="{Binding Entry.JobWorker.FullName}"/>

										<AutoCompleteBox Grid.Column="1"
										                 Text="{Binding Entry.JobName}"
										                 ItemsSource="{x:Static repository:JobNameRepository.JobNameList}"
										                 FilterMode="Contains"
										                 MinimumPrefixLength="1">

											<AutoCompleteBox.ItemTemplate>
												<DataTemplate x:DataType="enum:JobTitleEnum">
													<TextBlock Text="{Binding Name}"
													           FontSize="14"
													           Padding="4"/>
												</DataTemplate>
											</AutoCompleteBox.ItemTemplate>
										</AutoCompleteBox>

										<Button Grid.Column="2" Content="Stop" Command="{Binding StopTimerCommand}"/>
										<Button Grid.Column="3" Content="End" Margin="10 0" Command="{Binding EndTimerCommand}"/>
										<TextBlock Grid.Column="4" Text="{Binding Timer.StrTimer}"/>
									</Grid>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>

						<Button Content="Добавить новую запись"
						        HorizontalAlignment="Stretch"
						        VerticalAlignment="Center"
						        HorizontalContentAlignment="Center"
						        Command="{Binding AddNewTaskCommand}" />
						
						<Button Content="Сохранить"
						        HorizontalAlignment="Right"
						        Margin="0,10,10,10"
						        Command="{Binding SaveEntriesCommand}" />
					</StackPanel>
				</ScrollViewer>
			</Border>
		</DockPanel>


		<!-- Правая панель: сохранённые записи -->
		<DockPanel Grid.Column="2" Grid.Row="1" Background="DarkGray">
			<Border>
				<ScrollViewer>
					<StackPanel>
						<TextBlock Text="Сохранённые записи" 
						           FontWeight="Bold" 
						           Margin="5" 
						           HorizontalAlignment="Center"/>
						
						<ItemsControl ItemsSource="{x:Static repository:FinishedEntriesRepository.FinishedEntries}">
							<ItemsControl.ItemTemplate>
								<DataTemplate x:DataType="models:JobEntry">
									<Border BorderThickness="0,0,0,1" BorderBrush="Black" Margin="5,2">
										<StackPanel >
											<TextBlock Text="{Binding JobWorker.FullName}" FontWeight="Bold" Foreground="Black"/>
											<TextBlock Text="{Binding JobName}" Foreground="Black"/>
											<TextBlock Text="{Binding JobSample}" Foreground="Black"/>
										</StackPanel>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
						
						<Button Content="Экспорт"
						        HorizontalAlignment="Right"
						        Margin="0,10,10,10"
						        Command="{Binding ExportEntriesCommand}" />
					</StackPanel>
				</ScrollViewer>
			</Border>
		</DockPanel>
	</Grid>
</Window>